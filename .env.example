# Platform Acumatica
PLATFORM_ACUMATICA_URL=https://test.acumatica.stellarone.ai
PLATFORM_ACUMATICA_SERVICE_TOKEN=
PLATFORM_ACUMATICA_SOURCE_APP=finance

# Bank reconciliation workflow (scheduled daily 9AM MST via CRON_SECRET)
# Manual run (streams progress): POST /api/workflows/bank-reconciliation while signed in
# Cron: GET /api/workflows/bank-reconciliation/scheduled with CRON_SECRET
# Stream HMAC for manual runs: WORKFLOW_STREAM_SECRET, or CRON_SECRET, or SUPABASE_JWT_SECRET
AI_GATEWAY_API_KEY=
CRON_SECRET=
WORKFLOW_STREAM_SECRET=

# Platform Auth
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=
PLATFORM_AUTH_URL=https://test.auth.stellarone.ai
PLATFORM_AUTH_APP_ID=finance
PLATFORM_AUTH_SERVICE_TOKEN=

# Optional in local dev unless you need a shared parent-domain cookie.
SUPABASE_COOKIE_DOMAIN=
